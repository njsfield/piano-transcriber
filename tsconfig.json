{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": { "@/*": ["src/ui/*"], "ml-kmeans": ["node_modules/ml-kmeans/lib/index.d.ts"] },
    "types": ["node"]
  },
  "include": ["src/**/*", "examples/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
